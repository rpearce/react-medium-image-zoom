#!/usr/bin/env node

/**
 * Verifies that the React wrapper can be server-side rendered.
 *
 * The web component extends HTMLElement (browser-only), so we provide a
 * minimal global shim. In real SSR frameworks (Next.js, Remix), this is
 * handled by the 'use client' directive on the wrapper module.
 */

globalThis.HTMLElement ??= class HTMLElement {}
globalThis.customElements ??= { define() {}, get() {} }

const { createElement } = await import('react')
const { renderToString } = await import('react-dom/server')
const { default: Zoom, Controlled } = await import(
  '../packages/react-medium-image-zoom/dist/index.js'
)

try {
  renderToString(
    createElement(
      Zoom,
      null,
      createElement('img', { src: 'test.jpg', alt: 'test' }),
    ),
  )
  renderToString(
    createElement(
      Controlled,
      { isZoomed: false },
      createElement('img', { src: 'test.jpg', alt: 'test' }),
    ),
  )
} catch (err) {
  console.error('SSR check failed: component threw during server-side render')
  console.error(err)
  process.exit(1)
}
