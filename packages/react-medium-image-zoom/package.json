{
  "name": "react-medium-image-zoom",
  "version": "6.0.0",
  "license": "BSD-3-Clause",
  "description": "Accessible medium.com-style image zoom for React",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
