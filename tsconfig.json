{
  "compilerOptions": {
    "allowUnreachableCode": false,
    "declaration": true,
    "jsx": "react",
    "lib": ["dom", "dom.iterable", "esnext"],
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "outDir": "./dist",
    "removeComments": true,
    "skipLibCheck": true,
    "sourceMap": false,
    "target": "es2021"
  },
  "include": ["src/**/*", "stories/**/*"]
}
