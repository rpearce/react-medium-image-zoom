{
  "name": "react-medium-image-zoom-root",
  "private": true,
  "license": "BSD-3-Clause",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/rpearce/react-medium-image-zoom.git"
  },
  "homepage": "https://github.com/rpearce/react-medium-image-zoom",
  "bugs": "https://github.com/rpearce/react-medium-image-zoom/issues",
  "author": "Robert Pearce <me@robertwpearce.com> (https://robertwpearce.com)",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/rpearce"
    }
  ],
  "scripts": {
    "build": "pnpm --filter @rpearce/image-zoom build && pnpm --filter react-medium-image-zoom build",
    "build:docs": "rm -rf ./docs && mkdir ./docs && pnpm run storybook:build",
    "changeset": "changeset",
    "check:all": "conc 'pnpm:check:js' 'pnpm:check:types' 'pnpm:check:fmt'",
    "check:all:fix": "conc 'pnpm:check:js:fix' 'pnpm:check:types' 'pnpm:check:fmt:fix'",
    "check:fmt": "prettier --log-level warn --check '**/*.{ts,tsx,json,md,yml,yaml}'",
    "check:fmt:fix": "prettier --log-level warn --write '**/*.{ts,tsx,json,md,yml,yaml}'",
    "check:js": "eslint .",
    "check:js:fix": "eslint . --fix",
    "check:types": "pnpm -r run check:types",
    "test": "vitest run",
    "ci": "conc 'pnpm:check:all' 'pnpm:test' 'pnpm:build' 'pnpm:build:docs'",
    "contributors:add": "all-contributors add",
    "contributors:generate": "all-contributors generate",
    "prerelease": "pnpm run ci",
    "release": "changeset publish",
    "start": "pnpm run storybook:dev",
    "storybook:build": "storybook build --quiet -o docs",
    "storybook:dev": "storybook dev -p 6006"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@storybook/test-runner": "^0.24.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "all-contributors-cli": "^6.26.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-love": "^151.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.3.4",
    "happy-dom": "^20.8.9",
    "prettier": "^3.7.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.3.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild"
    ]
  }
}
